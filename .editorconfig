# EditorConfig - padrão de identação do projeto
# https://editorconfig.org
root = true

[*]
charset = utf-8
indent_style = space
indent_size = 4
end_of_line = crlf
insert_final_newline = true
trim_trailing_whitespace = true

# Arquivos JSON seguem a convenção de 2 espaços
[*.{json,jsonc}]
indent_size = 2

# Arquivos de marcação / config leve
[*.{yml,yaml}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false
